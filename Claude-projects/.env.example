# News Aggregation & Verification Platform - Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/news_platform

# Redis
REDIS_URL=redis://localhost:6379

# Twitter/X API
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# News APIs
NEWS_API_KEY=your_newsapi_org_key
GNEWS_API_KEY=your_gnews_api_key

# Anthropic/Claude API (for AI analysis)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google Fact Check API
GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_api_key

# Application
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
APP_NAME=News Platform
ENVIRONMENT=development

# Aggregation Settings
AGGREGATION_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_SOURCE=50
ARTICLES_PER_PAGE=20

# Credibility Scoring Weights
CROSS_CHECK_WEIGHT=0.3
SOURCE_CREDIBILITY_WEIGHT=0.25
AI_ANALYSIS_WEIGHT=0.25
FACT_CHECK_WEIGHT=0.2

# Thresholds
VERIFIED_THRESHOLD=70.0
NEEDS_REVIEW_THRESHOLD=40.0